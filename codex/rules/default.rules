prefix_rule(pattern=["adb", "-s", "emulator-5554", "shell", "ls", "-l", "/sdcard/Pictures/MoodBoard"], decision="allow")
prefix_rule(pattern=["/opt/homebrew/bin/zsh", "-lc", "for name in asking-codex committing cupertino finding-ios-simulator flowchart ios-simulator-photo-library-opener maestro-e2e-runner managing-mcp playwright-cli pushing-branch quality-review reviewing-codex reviewing-pr; do mkdir -p \"/Users/dealforest/.agents/skills/$name\"; rsync -a --delete \"codex/skills/$name/\" \"/Users/dealforest/.agents/skills/$name/\"; done"], decision="allow")
prefix_rule(pattern=["git", "checkout", "-b", "feature/migrate-codex-skills"], decision="allow")
prefix_rule(pattern=["git", "add", "aqua/aqua.yaml", "git/config", "git/hooks/pre-commit"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m", "chore: add gitleaks pre-commit hook"], decision="allow")
prefix_rule(pattern=["git", "add", "claude/skills/committing/SKILL.md", "opencode/commands/commit.md"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m", "docs: require branch before committing"], decision="allow")
prefix_rule(pattern=["git", "add", "codex/rules/default.rules"], decision="allow")
prefix_rule(pattern=["git", "commit", "-m", "chore: update codex command approvals"], decision="allow")
prefix_rule(pattern=["ps", "-axo", "pid,ppid,command"], decision="allow")
prefix_rule(pattern=["fish", "-lc", "codex-install-native"], decision="allow")
prefix_rule(pattern=["kill", "61305", "61285"], decision="allow")
prefix_rule(pattern=["git", "add"], decision="allow")
prefix_rule(pattern=["git", "commit"], decision="allow")
